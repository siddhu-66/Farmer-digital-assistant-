NODE_ENV=development
PORT=5000

# Frontend URL for CORS and cookies (use localhost, not 127.0.0.1)
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

MONGO_URI=mongodb://localhost:27017/farmer_assistant

# Minimum 16 characters. Required when NODE_ENV=production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20
JSON_LIMIT=100kb

# OpenWeatherMap — optional; fallback weather data is used when unset
OPENWEATHER_API_KEY=

# Optional ML service URL (defaults to http://localhost:5000)
ML_API_URL=http://localhost:5000
