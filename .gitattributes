# Enforce LF endings for source code
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.css  text eol=lf
*.mjs  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.csv  text eol=lf

# Keep CRLF for Windows batch files
*.bat  text eol=crlf

# Binary files (no conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.pdf  binary
*.lock binary
